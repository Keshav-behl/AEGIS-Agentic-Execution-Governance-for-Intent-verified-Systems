NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_RISK_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_RISK_MODEL=meta/llama-3.1-70b-instruct

JIRA_SITE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JIRA_PROJECT_KEY=AEG

SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APPROVAL_CHANNEL=#aegis-approvals

AEGIS_SIGNING_SECRET=generate-a-long-random-string-here
RISK_APPROVAL_THRESHOLD=40
TOKEN_EXPIRY_SECONDS=300

DATABASE_PATH=./data/aegis.db

# Map API keys to requester identities. Callers must send a known key in the
# X-AEGIS-API-Key header on POST /aegis/request.
AEGIS_API_KEYS={"your-api-key-here":"you@example.com"}

# Route approval requests to a different Slack channel by risk category
# (delete/bulk/compliance/general). Optional, falls back to SLACK_APPROVAL_CHANNEL.
SLACK_ROUTING_CHANNELS={"compliance":"#aegis-compliance"}

# How long a pending approval can go unanswered before it's escalated (seconds).
APPROVAL_SLA_SECONDS=120

# Optional: where to post the wider escalation notice, in addition to the
# threaded reply always posted under the original message. Leave unset to
# only use the threaded reply.
SLACK_ESCALATION_CHANNEL=#aegis-escalations
